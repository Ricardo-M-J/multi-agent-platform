# ============================================
# Multi-Agent Platform 环境变量配置
# ============================================

# Database (生产环境使用 PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/multi_agent

# LLM API Keys (至少配置一个)
MOONSHOT_API_KEY=your-moonshot-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
DOUBAO_API_KEY=your-doubao-api-key

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Agent Settings
AGENT_POLL_INTERVAL=2.0
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT=300

# ============================================
# 前端构建变量 (Vercel)
# ============================================
# VITE_API_BASE_URL=https://your-backend.railway.app/api
# VITE_WS_BASE_URL=wss://your-backend.railway.app/ws
